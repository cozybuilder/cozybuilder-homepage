# Supabase — Project Settings > API 에서 복사
# 이 파일을 .env.local 로 복사한 뒤 실제 값으로 채우세요. (.env.local 은 git 에 커밋되지 않음)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── 서버 전용(절대 NEXT_PUBLIC 금지) ──
# Platform Analytics 인제스트가 RLS 우회로 이벤트를 적재할 때 사용. Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Analytics auth_user_hash(HMAC) 솔트. 임의의 긴 난수 문자열. 변경 시 과거 해시와 불일치됨.
ANALYTICS_SALT=your-long-random-secret
